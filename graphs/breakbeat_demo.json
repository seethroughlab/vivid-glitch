{
  "nodes": {
    "clock_16th":  { "type": "Clock", "params": { "bpm": 680.0 } },
    "clock_8th":   { "type": "Clock", "params": { "bpm": 340.0 } },
    "clock_beat":  { "type": "Clock", "params": { "bpm": 170.0 } },
    "clock_half":  { "type": "Clock", "params": { "bpm": 85.0 } },
    "clock_trip":  { "type": "Clock", "params": { "bpm": 113.333 } },

    "kick":    { "type": "DrumKick",   "params": { "pitch": 55.0, "pitch_env": 180.0, "pitch_decay": 0.04, "decay": 0.35, "click": 0.4, "drive": 0.3, "overtones": 0.05, "volume": 0.8 } },
    "snare":   { "type": "DrumSnare",  "params": { "pitch": 190.0, "tone": 0.4, "noise": 0.6, "tone_decay": 0.08, "noise_decay": 0.15, "snappy": 0.7, "color": 0.3, "volume": 0.6 } },
    "hat_cl":  { "type": "DrumHiHat",  "params": { "decay": 0.04, "tone": 0.7, "ring": 0.6, "pitch": 1.0, "volume": 0.25 } },
    "hat_op":  { "type": "DrumHiHat",  "params": { "decay": 0.35, "tone": 0.5, "ring": 0.4, "pitch": 0.9, "volume": 0.3 } },
    "clap":    { "type": "DrumClap",   "params": { "decay": 0.25, "tone": 0.6, "sloppy": 0.4, "tail": 0.2, "stereo_width": 0.7, "tune": 1800.0, "volume": 0.35 } },
    "tom":     { "type": "DrumTom",    "params": { "pitch": 90.0, "bend": 0.5, "bend_time": 0.06, "color": 0.2, "tone": 0.4, "decay": 0.25, "volume": 0.35 } },

    "mix":         { "type": "Gain",       "params": { "gain": 0.9 } },
    "beat_repeat": { "type": "BeatRepeat", "params": { "chance": 0.25, "size": 0.088, "count": 3, "decay": 0.15, "mix": 1.0 } },
    "stutter":     { "type": "Stutter",    "params": { "chance": 0.3, "size": 0.088, "count": 4, "envelope": 0, "env_amount": 0.6, "mix": 1.0 } },
    "reverse":     { "type": "Reverse",    "params": { "chance": 0.2, "size": 0.18, "mix": 1.0 } },
    "scratch":     { "type": "Scratch",    "params": { "chance": 0.15, "size": 0.25, "speed": 1.2, "motion": 0, "mix": 1.0 } },
    "tape_stop":   { "type": "TapeStop",   "params": { "chance": 0.12, "stop_time": 0.35, "start_time": 0.15, "mode": 0, "mix": 1.0 } },

    "out1":    { "type": "audio_out",  "params": {} }
  },
  "connections": [
    { "from": "clock_beat/beat_phase",  "to": "kick/phase" },
    { "from": "clock_half/beat_phase",  "to": "snare/phase" },
    { "from": "clock_8th/beat_phase",   "to": "hat_cl/phase" },
    { "from": "clock_beat/beat_phase",  "to": "hat_op/phase" },
    { "from": "clock_half/beat_phase",  "to": "clap/phase" },
    { "from": "clock_trip/beat_phase",  "to": "tom/phase" },

    { "from": "kick/output",            "to": "mix/input" },
    { "from": "snare/output",           "to": "mix/input" },
    { "from": "hat_cl/output",          "to": "mix/input" },
    { "from": "hat_op/output",          "to": "mix/input" },
    { "from": "tom/output",             "to": "mix/input" },

    { "from": "clock_8th/beat_phase",   "to": "beat_repeat/phase" },
    { "from": "clock_beat/beat_phase",  "to": "stutter/phase" },
    { "from": "clock_half/beat_phase",  "to": "reverse/phase" },
    { "from": "clock_trip/beat_phase",  "to": "scratch/phase" },
    { "from": "clock_half/beat_phase",  "to": "tape_stop/phase" },

    { "from": "mix/output",             "to": "beat_repeat/input" },
    { "from": "beat_repeat/output",     "to": "stutter/input" },
    { "from": "stutter/output",         "to": "reverse/input" },
    { "from": "reverse/output",         "to": "scratch/input" },
    { "from": "scratch/output",         "to": "tape_stop/input" },
    { "from": "tape_stop/output",       "to": "out1/input" },

    { "from": "clap/output_left",       "to": "out1/left" },
    { "from": "clap/output_right",      "to": "out1/right" }
  ]
}
